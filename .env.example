# ============================================================
# DORIX — Environment Variables
# Copy this file to .env.local and fill in every value.
# Never commit .env.local to version control.
# ============================================================

# ── Clerk (Authentication) ───────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
CLERK_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── PostgreSQL on Hostinger VPS ───────────────────────────────
# Used for both Drizzle migrations and runtime DB access.
# Format: postgresql://[USER]:[PASSWORD]@[VPS_IP]:5432/[DB_NAME]?ssl=true
# Add ?ssl=true in production. Use port 6432 if you set up PgBouncer.
DATABASE_URL=postgresql://dorix:[PASSWORD]@[YOUR_VPS_IP]:5432/dorix

# ── Upstash Redis ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://
UPSTASH_REDIS_REST_TOKEN=

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_
PLATFORM_FEE_PERCENT=15

# ── Pusher Channels (Real-time) ───────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# ── Inngest (Background Jobs) ─────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=noreply@dorix.eu
RESEND_FROM_NAME=DORIX
ADMIN_EMAIL=admin@dorix.eu

# ── Cloudflare R2 (File Storage) ─────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=dorix-uploads
R2_PUBLIC_URL=https://

# ── Sentry (Error Monitoring) ─────────────────────────────────
# Create a project at sentry.io → Settings → Client Keys → DSN
NEXT_PUBLIC_SENTRY_DSN=https://
SENTRY_DSN=https://
SENTRY_ORG=
SENTRY_PROJECT=
# Generate at sentry.io → Settings → Auth Tokens (needed for source-map uploads in CI)
SENTRY_AUTH_TOKEN=

# ── App Config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DORIX
NODE_ENV=development

# ── Umami Analytics (self-hosted, GDPR-safe) ──────────────
# After first deploy: log in at http://<VPS-IP>:3001 (default: admin / umami → change immediately)
# Settings → Websites → Add → copy Website ID
# Self-hosted Umami uses admin username + password (POST /api/auth/login), NOT API keys
UMAMI_INTERNAL_URL=http://umami:3000
UMAMI_USERNAME=admin
UMAMI_PASSWORD=
UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
UMAMI_DB_PASSWORD=change-me-to-random-password
UMAMI_APP_SECRET=change-me-to-random-secret
